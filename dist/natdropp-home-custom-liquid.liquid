    #nd-formula-home .nd-leaf-rain i:nth-child(7) { --x: 88%; --y: -38%; --w: 26px; --o: .13; --r: 28deg; --d: 34s; --delay: -26s; --wind: -20px; }
    #nd-formula-home .nd-leaf-rain i:nth-child(8) { --x: 96%; --y: -10%; --w: 16px; --o: .12; --r: -18deg; --d: 27s; --delay: -14s; --wind: -30px; }
    #nd-formula-home .nd-leaf-rain i:nth-child(9) { --x: 12%; --y: 18%; --w: 14px; --o: .11; --r: 51deg; --d: 36s; --delay: -30s; --wind: 18px; }
