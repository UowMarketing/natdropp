{% liquid
  assign nd_product_handle = section.settings.product_handle | default: 'jabon-lavanda-flash'
  assign nd_product = all_products[nd_product_handle]
  assign nd_product_url = section.settings.product_url | default: '/products/jabon-lavanda-flash'
  assign nd_main_cta_label = section.settings.main_cta_label | default: 'Descubrir Lavanda Flash'
  assign nd_secondary_cta_label = section.settings.secondary_cta_label | default: 'Ver ingredientes'
  assign nd_logo_url = 'nd-logo.svg' | asset_url
  assign nd_product_main_url = 'nd-product-main.png' | asset_url
  assign nd_product_250_url = 'nd-product-250.webp' | asset_url
  assign nd_product_500_url = 'nd-product-500.webp' | asset_url
  assign nd_product_1l_url = 'nd-product-1l.webp' | asset_url
  assign nd_acene_url = 'nd-acene-badge.webp' | asset_url
  assign nd_lavender_1_url = 'nd-lavender-1.webp' | asset_url
  assign nd_lavender_2_url = 'nd-lavender-2.webp' | asset_url
  assign nd_leaf_1_url = 'nd-leaf-1.webp' | asset_url
  assign nd_leaf_2_url = 'nd-leaf-2.webp' | asset_url
  assign nd_leaf_3_url = 'nd-leaf-3.webp' | asset_url
%}

<section id="nd-formula-home" class="nd-home" data-nd-home data-nd-motion="{{ section.settings.enable_motion }}">
  <style>
    @import url("https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700;800&display=swap");

    #nd-formula-home,
    #nd-formula-home * {
      box-sizing: border-box;
    }

    #nd-formula-home {
      --nd-ink: #2C2C31;
      --nd-graphite: #707070;
      --nd-slate: #474747;
      --nd-fog: #F5F5F7;
      --nd-white: #FFFFFF;
      --nd-warm: #FAFAF7;
      --nd-purple: #5A4FD3;
      --nd-purple-deep: #3329A8;
      --nd-purple-2: #726DC9;
      --nd-lime: #DAF855;
      --nd-lilac: #ECE9FF;
      --nd-olive: #7E8B5B;
      --nd-oil: #D9A441;
      --nd-lavender: #C8B8FF;
      --nd-blue: #1974C9;
      --nd-border: rgba(29, 29, 31, .12);
      --nd-soft-border: rgba(29, 29, 31, .08);
      --nd-shadow: 0 34px 90px rgba(29, 29, 31, .16);
      --nd-radius-xl: 34px;
      --nd-radius-lg: 28px;
      --nd-radius-md: 18px;
      --nd-max: 1320px;
      --nd-progress: 0;
      color: var(--nd-ink);
      background: var(--nd-warm);
      font-family: Manrope, Inter, Montserrat, -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
      line-height: 1.45;
      overflow-x: clip;
      isolation: isolate;
      width: 100%;
    }

    @supports not (overflow: clip) {
      #nd-formula-home {
        overflow-x: hidden;
      }
    }

    #nd-formula-home a {
      color: inherit;
      text-decoration: none;
    }

    #nd-formula-home img,
    #nd-formula-home svg {
      display: block;
      max-width: 100%;
      height: auto;
    }

    #nd-formula-home button,
    #nd-formula-home select {
      font: inherit;
    }

    .nd-shell {
      width: min(100%, var(--nd-max));
      margin: 0 auto;
      padding: 0 34px;
    }

    .nd-section {
      position: relative;
      padding: clamp(84px, 9vw, 148px) 0;
    }

    .nd-eyebrow {
      margin: 0 0 16px;
      color: var(--nd-purple);
      font-size: 12px;
      font-weight: 900;
      line-height: 1.2;
      letter-spacing: 0;
      text-transform: uppercase;
    }

    .nd-h1,
    .nd-h2,
    .nd-h3 {
      margin: 0;
      color: var(--nd-ink);
      font-weight: 820;
      letter-spacing: 0;
      text-wrap: balance;
    }

    .nd-h1 {
      max-width: 760px;
      font-size: 104px;
      line-height: .88;
    }

    .nd-h2 {
      max-width: 900px;
      font-size: 72px;
      line-height: .95;
    }

    .nd-h3 {
      font-size: 28px;
      line-height: 1.06;
    }

    .nd-lede {
      margin: 26px 0 0;
      max-width: 660px;
      color: rgba(29, 29, 31, .82);
      font-size: 20px;
      line-height: 1.62;
      font-weight: 560;
      letter-spacing: 0;
    }

    .nd-copy {
      color: rgba(29, 29, 31, .72);
      font-size: 17px;
      line-height: 1.72;
      font-weight: 500;
    }

    #nd-formula-home .nd-btn {
      min-height: 54px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      border-radius: 999px;
      padding: 15px 25px;
      border: 1px solid transparent;
      font-size: 14px;
      font-weight: 900;
      line-height: 1;
      letter-spacing: 0;
      box-shadow: none;
      transition: transform .3s cubic-bezier(.2, .8, .2, 1), box-shadow .3s ease, background .3s ease, color .3s ease, border-color .3s ease;
    }

    #nd-formula-home .nd-btn::after {
      content: "";
      display: none;
    }

    #nd-formula-home .nd-btn:hover {
      transform: translateY(-2px);
    }

    #nd-formula-home .nd-btn-primary {
      color: var(--nd-white);
      background: linear-gradient(180deg, #665CE4 0%, var(--nd-purple) 100%);
      border-color: rgba(90, 79, 211, .92);
      box-shadow: 0 18px 42px rgba(90, 79, 211, .26), inset 0 1px 0 rgba(255, 255, 255, .22);
    }

    #nd-formula-home .nd-btn-primary:hover {
      color: var(--nd-white);
      background: linear-gradient(180deg, #5F54DC 0%, #473DC0 100%);
      box-shadow: 0 24px 58px rgba(90, 79, 211, .32), inset 0 1px 0 rgba(255, 255, 255, .24);
    }

    #nd-formula-home .nd-btn-secondary {
      min-height: 44px;
      padding: 10px 0;
      color: var(--nd-purple-deep);
      background: transparent;
      border-color: transparent;
      box-shadow: none;
    }

    #nd-formula-home .nd-btn-secondary::after {
      content: "→";
      display: block;
      width: auto;
      height: auto;
      color: currentColor;
      font-size: 15px;
      line-height: 1;
      transform: translateY(-1px);
      background: transparent;
      box-shadow: none;
    }

    #nd-formula-home .nd-btn-secondary:hover {
      color: var(--nd-purple);
      background: transparent;
      box-shadow: none;
    }

    .nd-btn:focus-visible,
    .nd-format-select:focus-visible,
    .nd-accordion summary:focus-visible {
      outline: 3px solid rgba(218, 248, 85, .8);
      outline-offset: 4px;
    }

    .nd-section-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 450px);
      gap: 44px;
      align-items: end;
      margin-bottom: 52px;
    }

    .nd-section-head p {
      margin: 0;
    }

    .nd-hero {
      position: relative;
      min-height: min(980px, calc(100vh - 12px));
      padding: 34px 0 68px;
      overflow: hidden;
      background:
        radial-gradient(circle at 16% 18%, rgba(218, 248, 85, .24) 0 8%, rgba(218, 248, 85, 0) 26%),
        radial-gradient(circle at 80% 18%, rgba(90, 79, 211, .24) 0 12%, rgba(90, 79, 211, 0) 34%),
        radial-gradient(circle at 70% 74%, rgba(25, 116, 201, .13) 0 12%, rgba(25, 116, 201, 0) 36%),
        linear-gradient(155deg, #FFFFFF 0%, #FAFAF7 38%, #F1EFFF 100%);
    }

    .nd-hero::before {
      content: "";
      position: absolute;
      inset: auto -8% -20% -8%;
      height: 46%;
      background:
        radial-gradient(ellipse at 60% 18%, rgba(255, 255, 255, .94) 0 38%, rgba(255, 255, 255, 0) 64%),
        linear-gradient(180deg, rgba(255, 255, 255, 0), rgba(200, 184, 255, .38));
      pointer-events: none;
    }

    .nd-hero::after {
      content: "";
      position: absolute;
      inset: 0;
      opacity: .54;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(29, 29, 31, .032) 1px, transparent 1px),
        linear-gradient(90deg, rgba(29, 29, 31, .025) 1px, transparent 1px);
      background-size: 88px 88px;
      mask-image: radial-gradient(circle at 50% 45%, #000 0 36%, transparent 72%);
    }

    .nd-hero-inner {
      position: relative;
      z-index: 2;
      min-height: calc(min(980px, 100vh) - 102px);
      display: grid;
      grid-template-rows: auto 1fr;
      gap: 24px;
    }

    .nd-hero-top {
      position: relative;
      z-index: 12;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 22px;
      min-height: 48px;
    }

    .nd-logo-mark {
      width: clamp(158px, 12vw, 210px);
      display: inline-flex;
      align-items: center;
    }

    .nd-logo-mark img {
      width: 100%;
      height: auto;
    }

    .nd-hero-origin {
      margin: 0;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      color: var(--nd-ink);
      font-size: 11px;
      font-weight: 950;
      letter-spacing: 0;
      text-transform: uppercase;
      background: transparent;
      border: 0;
      padding: 0;
    }

    .nd-hero-origin::before {
      content: "";
      width: 18px;
      height: 12px;
      border-radius: 2px;
      background: linear-gradient(180deg, #AA151B 0 25%, #F1BF00 25% 75%, #AA151B 75% 100%);
      box-shadow: none;
    }

    .nd-hero-grid {
      display: grid;
      grid-template-columns: minmax(0, .86fr) minmax(520px, 1.14fr);
      gap: clamp(28px, 4vw, 72px);
      align-items: center;
    }

    .nd-hero-copy {
      position: relative;
      z-index: 3;
      padding: 48px 0 42px;
    }

    .nd-hero-meta {
      display: grid;
      gap: 8px;
      margin: 0 0 22px;
    }

    .nd-hero-meta strong {
      color: var(--nd-purple);
      font-size: 13px;
      line-height: 1;
      font-weight: 950;
      letter-spacing: 0;
      text-transform: uppercase;
    }

    .nd-hero-meta span {
      color: rgba(29, 29, 31, .66);
      font-size: 14px;
      line-height: 1.35;
      font-weight: 850;
    }

    .nd-hero-claim {
      display: flex;
      flex-wrap: wrap;
      gap: 8px 15px;
      margin: 22px 0 0;
      color: rgba(29, 29, 31, .64);
      font-size: 13px;
      font-weight: 850;
      line-height: 1.35;
    }

    .nd-hero-claim span {
      position: relative;
    }

    .nd-hero-claim span:not(:first-child)::before {
      content: "";
      position: absolute;
      left: -9px;
      top: .55em;
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: var(--nd-lime);
    }

    .nd-hero-title-accent {
      color: var(--nd-purple);
    }

    .nd-hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      align-items: center;
      margin-top: 32px;
    }

    .nd-hero-proof {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0;
      max-width: 640px;
      margin-top: 36px;
      border-top: 1px solid rgba(29, 29, 31, .14);
    }

    .nd-proof-tile {
      min-height: auto;
      padding: 18px 22px 0 0;
      border-radius: 0;
      background: transparent;
      border: 0;
      backdrop-filter: none;
    }

    .nd-proof-tile:not(:last-child) {
      border-right: 1px solid rgba(29, 29, 31, .1);
      margin-right: 18px;
    }

    .nd-proof-tile strong {
      display: block;
      color: var(--nd-ink);
      font-size: 16px;
      line-height: 1.1;
      font-weight: 950;
      letter-spacing: 0;
    }

    .nd-proof-tile span {
      display: block;
      margin-top: 7px;
      color: rgba(29, 29, 31, .64);
      font-size: 12px;
      line-height: 1.35;
      font-weight: 700;
    }

    .nd-hero-visual {
      position: relative;
      min-height: clamp(610px, 62vw, 820px);
      display: grid;
      place-items: center;
      perspective: 1200px;
    }

    .nd-studio-plate {
      position: absolute;
      inset: 9% -2% 4% 0;
      border-radius: 48px;
      background:
        radial-gradient(circle at 48% 44%, rgba(255, 255, 255, .92) 0 24%, rgba(255, 255, 255, .08) 56%, rgba(255, 255, 255, 0) 68%),
        radial-gradient(circle at 64% 26%, rgba(218, 248, 85, .28) 0 8%, rgba(218, 248, 85, 0) 28%),
        linear-gradient(145deg, rgba(255, 255, 255, .68), rgba(236, 233, 255, .7));
      border: 1px solid rgba(255, 255, 255, .72);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .82), 0 52px 120px rgba(90, 79, 211, .18);
      transform: rotateX(0deg) rotateY(-4deg);
    }

    .nd-studio-plate::after {
      content: "";
      position: absolute;
      left: 10%;
      right: 5%;
      bottom: 9%;
      height: 18%;
      border-radius: 50%;
      background: radial-gradient(ellipse, rgba(29, 29, 31, .2), rgba(29, 29, 31, 0) 66%);
      filter: blur(9px);
    }

    .nd-product-campaign {
      position: relative;
      width: min(100%, 820px);
      height: clamp(560px, 56vw, 780px);
      transform-style: preserve-3d;
      transform: translateY(calc(var(--nd-progress) * -18px));
    }

    .nd-product-campaign::before {
      content: "";
      position: absolute;
      inset: 18% 4% 1% 8%;
      border-radius: 48px;
      background:
        linear-gradient(110deg, rgba(90, 79, 211, .12), rgba(218, 248, 85, .15), rgba(217, 164, 65, .12)),
        radial-gradient(circle at 50% 55%, rgba(255, 255, 255, .9), rgba(255, 255, 255, 0) 58%);
      filter: blur(4px);
      transform: translateZ(-60px);
    }

    .nd-liquid-streak {
      position: absolute;
      z-index: 1;
      left: -8%;
      right: -6%;
      top: 32%;
      height: 190px;
      border-radius: 999px;
      background:
        radial-gradient(ellipse at 36% 50%, rgba(217, 164, 65, .5), rgba(217, 164, 65, 0) 48%),
        linear-gradient(94deg, rgba(217, 164, 65, 0) 0%, rgba(217, 164, 65, .38) 31%, rgba(218, 248, 85, .22) 52%, rgba(90, 79, 211, .16) 72%, rgba(90, 79, 211, 0) 100%);
      filter: blur(22px);
      opacity: .5;
      transform: rotate(-8deg) translate3d(calc(var(--nd-progress) * -12px), 0, -20px);
      mix-blend-mode: normal;
    }

    .nd-product-group {
      position: absolute;
      z-index: 4;
      inset: 0;
      transform: translate3d(0, calc(var(--nd-progress) * -24px), 90px);
    }

    .nd-bottle {
      position: absolute;
      object-fit: contain;
      filter: drop-shadow(0 34px 44px rgba(29, 29, 31, .24));
      transform-origin: 50% 95%;
    }

    .nd-bottle-1l {
      left: 7%;
      bottom: 4%;
      width: 41%;
      z-index: 2;
      transform: rotate(-1.5deg);
    }

    .nd-bottle-500 {
      left: 37%;
      bottom: 4%;
      width: 34%;
      z-index: 3;
      transform: rotate(.4deg) translateY(-3%);
    }

    .nd-bottle-250 {
      right: 5%;
      bottom: 4%;
      width: 28%;
      z-index: 4;
      transform: rotate(1.6deg) translateY(3%);
    }

    .nd-transition-band {
      background: var(--nd-fog);
      padding: 76px 0;
    }

    .nd-intro-grid {
      display: grid;
      grid-template-columns: minmax(0, .82fr) minmax(320px, 1fr);
      gap: 70px;
      align-items: center;
    }

    .nd-intro-note {
      max-width: 560px;
    }

    .nd-intro-list {
      display: grid;
      gap: 0;
      border-top: 1px solid rgba(29, 29, 31, .12);
    }

    .nd-intro-list p {
      position: relative;
      margin: 0;
      padding: 23px 0 23px 34px;
      border-bottom: 1px solid rgba(29, 29, 31, .12);
      color: rgba(29, 29, 31, .78);
      font-size: 16px;
      line-height: 1.58;
      font-weight: 650;
    }

    .nd-intro-list p::before {
      content: "";
      position: absolute;
      left: 0;
      top: 30px;
      width: 13px;
      height: 13px;
      border-radius: 50%;
      background: var(--nd-lime);
      box-shadow: inset 0 0 0 4px rgba(255, 255, 255, .74), 0 0 0 4px rgba(218, 248, 85, .18);
    }

    .nd-formula {
      padding: 0;
      background:
        radial-gradient(circle at 12% 18%, rgba(218, 248, 85, .18), transparent 23%),
        radial-gradient(circle at 80% 42%, rgba(90, 79, 211, .2), transparent 32%),
        linear-gradient(180deg, #FFFFFF 0%, #F5F5F7 100%);
    }

    .nd-formula-scroll {
      min-height: 330vh;
      position: relative;
    }

    .nd-formula-stage {
      position: sticky;
      top: 0;
      min-height: 100vh;
      display: grid;
      align-items: center;
      overflow: hidden;
      padding: 90px 0;
    }

    .nd-formula-layout {
      display: grid;
      grid-template-columns: minmax(0, .86fr) minmax(520px, 1.14fr);
      gap: 58px;
      align-items: center;
    }

    .nd-step-panel {
      position: relative;
      z-index: 3;
    }

    .nd-step-count {
      margin: 0 0 14px;
      display: inline-flex;
      align-items: center;
      gap: 9px;
      color: var(--nd-purple);
      font-size: 12px;
      font-weight: 950;
      text-transform: uppercase;
      letter-spacing: 0;
    }

    .nd-step-count::before {
      content: "";
      width: 44px;
      height: 2px;
      border-radius: 99px;
      background: var(--nd-purple);
    }

    .nd-step-copy {
      display: grid;
      margin-top: 34px;
      gap: 12px;
    }

    .nd-step-copy article {
      padding: 18px 20px;
      border-radius: 24px;
      border: 1px solid rgba(29, 29, 31, .08);
      background: rgba(255, 255, 255, .64);
      color: rgba(29, 29, 31, .62);
      backdrop-filter: blur(16px);
      transition: transform .45s ease, background .45s ease, color .45s ease, border-color .45s ease, box-shadow .45s ease;
    }

    .nd-step-copy article.is-active {
      color: var(--nd-ink);
      background: rgba(255, 255, 255, .94);
      border-color: rgba(90, 79, 211, .25);
      box-shadow: 0 24px 60px rgba(90, 79, 211, .12);
      transform: translateX(10px);
    }

    .nd-step-copy h3 {
      margin: 0;
      color: inherit;
      font-size: 18px;
      line-height: 1.15;
      font-weight: 950;
      letter-spacing: 0;
    }

    .nd-step-copy p {
      margin: 8px 0 0;
      font-size: 14px;
      line-height: 1.54;
      font-weight: 600;
    }

    .nd-progress-track {
      width: min(420px, 100%);
      height: 6px;
      margin-top: 30px;
      border-radius: 99px;
      background: rgba(29, 29, 31, .08);
      overflow: hidden;
    }

    .nd-progress-track span {
      display: block;
      width: calc(var(--nd-progress) * 100%);
      height: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, var(--nd-purple), var(--nd-lime));
      transition: width .16s linear;
    }

    .nd-formula-canvas {
      position: relative;
      height: min(760px, 78vh);
      min-height: 560px;
      border-radius: 46px;
      background:
        radial-gradient(circle at 48% 38%, rgba(255, 255, 255, .98) 0 16%, rgba(255, 255, 255, .36) 44%, rgba(255, 255, 255, 0) 65%),
        linear-gradient(145deg, rgba(255, 255, 255, .72), rgba(236, 233, 255, .62));
      border: 1px solid rgba(255, 255, 255, .78);
      box-shadow: var(--nd-shadow), inset 0 1px 0 rgba(255, 255, 255, .9);
      overflow: hidden;
    }

    .nd-formula-canvas::before {
      content: "";
      position: absolute;
      inset: 10%;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(218, 248, 85, .26), rgba(218, 248, 85, 0) 62%);
      transform: scale(calc(.75 + var(--nd-progress) * .54));
      opacity: calc(.2 + var(--nd-progress) * .5);
    }

    .nd-formula-product {
      position: absolute;
      z-index: 7;
      right: 8%;
      bottom: 4%;
      width: 28%;
      object-fit: contain;
      filter: drop-shadow(0 38px 44px rgba(29, 29, 31, .24));
      opacity: calc(.28 + var(--nd-progress) * .72);
      transform: translate3d(calc((1 - var(--nd-progress)) * 26px), calc((1 - var(--nd-progress)) * 30px), 0) scale(calc(.9 + var(--nd-progress) * .1));
    }

    .nd-mobile-story {
      display: none;
    }

    .nd-reveal-product {
      overflow: hidden;
      background:
        radial-gradient(circle at 86% 18%, rgba(218, 248, 85, .18), transparent 22%),
        linear-gradient(180deg, #F5F5F7, #FFFFFF);
    }

    .nd-product-reveal-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(460px, .86fr);
      gap: 60px;
      align-items: center;
    }

    .nd-product-stage {
      position: relative;
      min-height: 620px;
      display: grid;
      place-items: center;
      border-radius: 46px;
      background:
        radial-gradient(circle at 50% 42%, rgba(255, 255, 255, .96) 0 28%, rgba(255, 255, 255, 0) 62%),
        linear-gradient(145deg, rgba(236, 233, 255, .8), rgba(255, 255, 255, .64));
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .9);
      overflow: hidden;
    }

    .nd-product-stage::after {
      content: "";
      position: absolute;
      left: 18%;
      right: 18%;
      bottom: 12%;
      height: 16%;
      border-radius: 50%;
      background: radial-gradient(ellipse, rgba(29, 29, 31, .22), rgba(29, 29, 31, 0) 70%);
      filter: blur(10px);
    }

    .nd-product-stage img {
      position: relative;
      z-index: 3;
      width: min(44%, 360px);
      height: auto;
      filter: drop-shadow(0 34px 40px rgba(29, 29, 31, .23));
    }

    .nd-product-copy {
      position: relative;
      z-index: 2;
    }

    .nd-specs {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin: 30px 0 0;
      padding: 0;
      list-style: none;
    }

    .nd-specs li {
      min-height: 92px;
      padding: 17px;
      border-radius: 22px;
      background: #fff;
      border: 1px solid rgba(29, 29, 31, .08);
      color: rgba(29, 29, 31, .74);
      font-size: 13px;
      font-weight: 800;
      line-height: 1.35;
    }

    .nd-specs li strong {
      display: block;
      color: var(--nd-ink);
      margin-bottom: 5px;
      font-size: 16px;
      font-weight: 950;
      letter-spacing: 0;
    }

    .nd-benefits {
      background:
        radial-gradient(circle at 8% 8%, rgba(90, 79, 211, .12), transparent 24%),
        radial-gradient(circle at 84% 90%, rgba(218, 248, 85, .18), transparent 24%),
        #FFFFFF;
    }

    .nd-benefit-system {
      display: grid;
      grid-template-columns: 1.05fr .95fr;
      gap: 24px;
      align-items: stretch;
    }

    .nd-benefit-hero {
      position: relative;
      min-height: 560px;
      padding: 42px;
      border-radius: 42px;
      color: #fff;
      overflow: hidden;
      background:
        radial-gradient(circle at 82% 22%, rgba(218, 248, 85, .44), transparent 20%),
        linear-gradient(145deg, #27205F 0%, var(--nd-purple) 54%, #7B73E6 100%);
      box-shadow: 0 34px 94px rgba(90, 79, 211, .22);
    }

    .nd-benefit-hero::after {
      content: "";
      position: absolute;
      inset: auto -10% -22% 20%;
      height: 52%;
      border-radius: 50%;
      background: radial-gradient(ellipse, rgba(255, 255, 255, .2), rgba(255, 255, 255, 0) 68%);
    }

    .nd-benefit-hero h2,
    .nd-benefit-hero p,
    .nd-benefit-hero .nd-eyebrow {
      position: relative;
      z-index: 2;
      color: #fff;
    }

    .nd-benefit-hero .nd-eyebrow {
      color: var(--nd-lime);
    }

    .nd-benefit-hero p {
      max-width: 560px;
      color: rgba(255, 255, 255, .78);
    }

    .nd-benefit-mark {
      position: relative;
      z-index: 2;
      width: min(240px, 62%);
      margin-top: 34px;
      padding: 18px 20px;
      border-radius: 22px;
      background: rgba(255, 255, 255, .96);
      border: 1px solid rgba(255, 255, 255, .72);
      opacity: .98;
      filter: none;
    }

    .nd-benefit-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .nd-benefit-card {
      min-height: 170px;
      padding: 24px;
      border-radius: 28px;
      border: 1px solid rgba(29, 29, 31, .08);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, .94), rgba(250, 250, 247, .82));
      box-shadow: 0 18px 44px rgba(29, 29, 31, .05);
    }

    .nd-benefit-icon {
      width: 42px;
      height: 42px;
      display: grid;
      place-items: center;
      margin-bottom: 18px;
      border-radius: 16px;
      color: var(--nd-purple);
      background: linear-gradient(145deg, var(--nd-lilac), #fff);
      border: 1px solid rgba(90, 79, 211, .12);
    }

    .nd-benefit-icon svg {
      width: 22px;
      height: 22px;
      stroke: currentColor;
      stroke-width: 2.2;
      fill: none;
    }

    .nd-benefit-card h3 {
      margin: 0;
      color: var(--nd-ink);
      font-size: 18px;
      font-weight: 950;
      letter-spacing: 0;
    }

    .nd-benefit-card p {
      margin: 9px 0 0;
      color: rgba(29, 29, 31, .66);
      font-size: 14px;
      line-height: 1.55;
      font-weight: 600;
    }

    .nd-ingredients {
      background:
        linear-gradient(180deg, #FAFAF7, #F5F5F7);
      overflow: hidden;
    }

    .nd-dossier {
      position: relative;
      border-radius: 42px;
      background:
        radial-gradient(circle at 84% 14%, rgba(218, 248, 85, .18), transparent 28%),
        radial-gradient(circle at 18% 86%, rgba(90, 79, 211, .14), transparent 26%),
        #FFFFFF;
      border: 1px solid rgba(29, 29, 31, .08);
      box-shadow: 0 34px 90px rgba(29, 29, 31, .08);
      overflow: hidden;
    }

    .nd-dossier::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(29, 29, 31, .055) 1px, transparent 1px),
        linear-gradient(90deg, rgba(29, 29, 31, .035) 1px, transparent 1px);
      background-size: 1px 112px, 25% 1px;
      opacity: .42;
      pointer-events: none;
    }

    .nd-dossier-top {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: minmax(0, .76fr) minmax(320px, 1fr);
      gap: 34px;
      padding: 40px;
      border-bottom: 1px solid rgba(29, 29, 31, .08);
    }

    .nd-dossier-top p {
      margin: 0;
      align-self: end;
    }

    .nd-ingredient-families {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .nd-family {
      min-height: 520px;
      padding: 32px 24px;
      border-right: 1px solid rgba(29, 29, 31, .08);
    }

    .nd-family:last-child {
      border-right: 0;
    }

    .nd-family-label {
      margin: 0 0 18px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--nd-purple);
      font-size: 11px;
      font-weight: 950;
      letter-spacing: 0;
      text-transform: uppercase;
    }

    .nd-family-label::before {
      content: "";
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: var(--nd-lime);
    }

    .nd-ingredient-item {
      padding: 17px 0;
      border-top: 1px solid rgba(29, 29, 31, .08);
    }

    .nd-ingredient-item h3 {
      margin: 0;
      color: var(--nd-ink);
      font-size: 16px;
      line-height: 1.18;
      font-weight: 950;
      letter-spacing: 0;
    }

    .nd-inci {
      display: inline-flex;
      margin-top: 8px;
      padding: 0;
      border-radius: 0;
      background: transparent;
      color: var(--nd-purple-deep);
      font-size: 10px;
      font-weight: 950;
      letter-spacing: 0;
      text-transform: uppercase;
      border-bottom: 1px solid rgba(90, 79, 211, .3);
    }

    .nd-ingredient-item p {
      margin: 10px 0 0;
      color: rgba(29, 29, 31, .68);
      font-size: 13px;
      line-height: 1.48;
      font-weight: 600;
    }

    .nd-footnote {
      position: relative;
      z-index: 2;
      margin: 0;
      padding: 24px 40px 34px;
      border-top: 1px solid rgba(29, 29, 31, .08);
      color: rgba(29, 29, 31, .62);
      font-size: 13px;
      line-height: 1.6;
      font-weight: 650;
    }

    .nd-multiuse {
      background:
        radial-gradient(circle at 16% 16%, rgba(218, 248, 85, .18), transparent 24%),
        radial-gradient(circle at 84% 18%, rgba(90, 79, 211, .16), transparent 26%),
        #FFFFFF;
      overflow: hidden;
    }

    .nd-use-board {
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, .92fr) minmax(450px, 1.08fr);
      gap: 34px;
      min-height: 700px;
      padding: 34px;
      border-radius: 46px;
      background:
        linear-gradient(145deg, rgba(250, 250, 247, .96), rgba(236, 233, 255, .62));
      border: 1px solid rgba(29, 29, 31, .08);
      box-shadow: 0 34px 90px rgba(29, 29, 31, .08);
      overflow: hidden;
    }

    .nd-use-board::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 68% 42%, rgba(255, 255, 255, .95), transparent 30%),
        linear-gradient(100deg, rgba(217, 164, 65, 0), rgba(217, 164, 65, .16), rgba(90, 79, 211, 0));
      pointer-events: none;
    }

    .nd-use-copy,
    .nd-use-stage {
      position: relative;
      z-index: 2;
    }

    .nd-use-copy {
      align-self: center;
      padding: 18px;
    }

    .nd-use-groups {
      display: grid;
      gap: 14px;
      margin-top: 34px;
    }

    .nd-use-group {
      padding: 20px;
      border-radius: 26px;
      background: rgba(255, 255, 255, .72);
      border: 1px solid rgba(29, 29, 31, .08);
      backdrop-filter: blur(16px);
    }

    .nd-use-group h3 {
      margin: 0 0 14px;
      color: var(--nd-ink);
      font-size: 16px;
      line-height: 1;
      font-weight: 950;
      letter-spacing: 0;
    }

    .nd-use-tags {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px 18px;
    }

    .nd-use-tags span {
      display: flex;
      align-items: center;
      gap: 10px;
      min-height: 28px;
      padding: 0;
      border-radius: 0;
      background: transparent;
      color: rgba(29, 29, 31, .82);
      font-size: 13px;
      font-weight: 850;
      line-height: 1.25;
    }

    .nd-use-tags span::before {
      content: "";
      flex: 0 0 auto;
      width: 18px;
      height: 2px;
      background: var(--nd-purple);
    }

    .nd-use-stage {
      min-height: 600px;
      display: grid;
      place-items: center;
    }

    .nd-use-stage img {
      width: min(38vw, 360px);
      height: auto;
      filter: drop-shadow(0 38px 44px rgba(29, 29, 31, .24));
    }

    .nd-use-orbit {
      position: absolute;
      inset: 9% 7%;
      border-radius: 42px;
      border: 0;
      background:
        radial-gradient(circle at 52% 45%, rgba(255, 255, 255, .84), transparent 35%),
        linear-gradient(120deg, rgba(90, 79, 211, .08), rgba(218, 248, 85, .1), rgba(217, 164, 65, .08));
      pointer-events: none;
    }

    .nd-use-orbit span {
      position: absolute;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 9px;
      min-width: 0;
      min-height: 0;
      padding: 0;
      border-radius: 0;
      background: transparent;
      border: 0;
      color: var(--nd-purple-deep);
      font-size: 11px;
      font-weight: 950;
      letter-spacing: 0;
      text-transform: uppercase;
      box-shadow: none;
      backdrop-filter: none;
      white-space: nowrap;
    }

    .nd-use-orbit span::before {
      content: "";
      width: 24px;
      height: 2px;
      background: var(--nd-lime);
    }

    .nd-use-orbit span:nth-child(1) { left: 4%; top: 13%; }
    .nd-use-orbit span:nth-child(2) { right: 7%; top: 8%; }
    .nd-use-orbit span:nth-child(3) { left: -3%; top: 48%; }
    .nd-use-orbit span:nth-child(4) { right: -2%; top: 48%; }
    .nd-use-orbit span:nth-child(5) { left: 16%; bottom: 5%; }
    .nd-use-orbit span:nth-child(6) { right: 14%; bottom: 6%; }

    .nd-formats {
      background:
        linear-gradient(180deg, #FFFFFF, #F5F5F7);
    }

    .nd-format-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 18px;
    }

    .nd-format-card {
      position: relative;
      min-height: 540px;
      display: grid;
      grid-template-rows: 1fr auto;
      padding: 28px;
      border-radius: 34px;
      background:
        radial-gradient(circle at 50% 32%, rgba(255, 255, 255, .96), rgba(255, 255, 255, 0) 58%),
        linear-gradient(160deg, #FFFFFF, #ECE9FF);
      border: 1px solid rgba(29, 29, 31, .08);
      overflow: hidden;
      box-shadow: 0 24px 64px rgba(29, 29, 31, .07);
    }

    .nd-format-card::after {
      content: "";
      position: absolute;
      left: 17%;
      right: 17%;
      bottom: 118px;
      height: 54px;
      border-radius: 50%;
      background: radial-gradient(ellipse, rgba(29, 29, 31, .2), rgba(29, 29, 31, 0) 70%);
      filter: blur(8px);
    }

    .nd-format-img {
      position: relative;
      z-index: 2;
      align-self: end;
      justify-self: center;
      width: min(58%, 260px);
      height: auto;
      max-height: 360px;
      object-fit: contain;
      filter: drop-shadow(0 28px 34px rgba(29, 29, 31, .18));
    }

    .nd-format-info {
      position: relative;
      z-index: 3;
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 18px;
      padding-top: 24px;
    }

    .nd-format-info h3 {
      margin: 0;
      color: var(--nd-ink);
      font-size: 30px;
      line-height: .95;
      font-weight: 950;
      letter-spacing: 0;
    }

    .nd-format-info p {
      margin: 8px 0 0;
      color: rgba(29, 29, 31, .62);
      font-size: 13px;
      line-height: 1.4;
      font-weight: 750;
    }

    .nd-format-price {
      min-width: max-content;
      color: var(--nd-purple-deep);
      font-size: 14px;
      font-weight: 950;
    }

    .nd-shop-panel {
      margin-top: 24px;
      padding: 24px;
      border-radius: 30px;
      background: #fff;
      border: 1px solid rgba(29, 29, 31, .08);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
    }

    .nd-format-select {
      min-height: 52px;
      border-radius: 999px;
      border: 1px solid rgba(29, 29, 31, .14);
      padding: 0 44px 0 18px;
      background: #fff;
      color: var(--nd-ink);
      font-weight: 800;
    }

    .nd-trust {
      background:
        radial-gradient(circle at 12% 20%, rgba(218, 248, 85, .18), transparent 26%),
        linear-gradient(180deg, #F5F5F7, #FAFAF7);
    }

    .nd-trust-panel {
      display: grid;
      grid-template-columns: minmax(300px, .72fr) minmax(0, 1fr);
      gap: 30px;
      align-items: stretch;
      border-radius: 44px;
      background:
        linear-gradient(145deg, rgba(255, 255, 255, .92), rgba(236, 233, 255, .58));
      border: 1px solid rgba(29, 29, 31, .08);
      overflow: hidden;
      box-shadow: 0 34px 90px rgba(29, 29, 31, .08);
    }

    .nd-trust-badge {
      display: grid;
      place-items: center;
      min-height: 420px;
      padding: 42px;
      background:
        radial-gradient(circle at 50% 42%, rgba(255, 255, 255, .92), transparent 54%),
        linear-gradient(180deg, rgba(218, 248, 85, .2), rgba(255, 255, 255, .44));
    }

    .nd-trust-badge img {
      width: min(330px, 74%);
      height: auto;
      filter: drop-shadow(0 24px 36px rgba(29, 29, 31, .13));
    }

    .nd-trust-copy {
      padding: 46px;
      align-self: center;
    }

    .nd-no-list {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px 22px;
      margin-top: 30px;
    }

    .nd-no-list span {
      display: flex;
      align-items: center;
      gap: 10px;
      min-height: 30px;
      padding: 0;
      border-radius: 0;
      background: transparent;
      color: rgba(29, 29, 31, .76);
      font-size: 13px;
      font-weight: 900;
      line-height: 1.25;
    }

    .nd-no-list span::before {
      content: "";
      flex: 0 0 auto;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--nd-lime);
      box-shadow: 0 0 0 4px rgba(218, 248, 85, .18);
    }

    .nd-faq {
      background: #FFFFFF;
    }

    .nd-faq-grid {
      display: grid;
      grid-template-columns: minmax(0, .72fr) minmax(0, 1fr);
      gap: 60px;
      align-items: start;
    }

    .nd-accordion {
      display: grid;
      gap: 12px;
    }

    .nd-accordion details {
      border-radius: 24px;
      border: 1px solid rgba(29, 29, 31, .1);
      background: var(--nd-fog);
      overflow: hidden;
    }

    .nd-accordion summary {
      cursor: pointer;
      list-style: none;
      padding: 22px 58px 22px 24px;
      position: relative;
      color: var(--nd-ink);
      font-size: 17px;
      line-height: 1.25;
      font-weight: 950;
      letter-spacing: 0;
    }

    .nd-accordion summary::-webkit-details-marker {
      display: none;
    }

    .nd-accordion summary::after {
      content: "+";
      position: absolute;
      right: 22px;
      top: 50%;
      width: 28px;
      height: 28px;
      display: grid;
      place-items: center;
      border-radius: 999px;
      background: #fff;
      color: var(--nd-purple);
      transform: translateY(-50%);
      font-size: 20px;
      line-height: 1;
    }

    .nd-accordion details[open] summary::after {
      content: "\2212";
    }

    .nd-accordion p {
      margin: 0;
      padding: 0 24px 24px;
      color: rgba(29, 29, 31, .68);
      font-size: 15px;
      line-height: 1.62;
      font-weight: 600;
    }

    .nd-final {
      position: relative;
      padding: clamp(92px, 10vw, 156px) 0;
      overflow: hidden;
      background:
        radial-gradient(circle at 20% 18%, rgba(218, 248, 85, .3), transparent 26%),
        radial-gradient(circle at 82% 30%, rgba(200, 184, 255, .32), transparent 28%),
        linear-gradient(135deg, #251D66 0%, var(--nd-purple) 58%, #827AE6 100%);
      color: #fff;
    }

    .nd-final::before {
      content: "";
      position: absolute;
      inset: auto -10% -28% -10%;
      height: 52%;
      background: radial-gradient(ellipse, rgba(255, 255, 255, .24), rgba(255, 255, 255, 0) 70%);
      pointer-events: none;
    }

    .nd-final-grid {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: minmax(0, .88fr) minmax(400px, 1fr);
      gap: 42px;
      align-items: center;
    }

    .nd-final h2,
    .nd-final p,
    .nd-final .nd-eyebrow {
      color: #fff;
    }

    .nd-final .nd-eyebrow {
      color: var(--nd-lime);
    }

    .nd-final p {
      max-width: 600px;
      color: rgba(255, 255, 255, .8);
    }

    .nd-final-product {
      position: relative;
      min-height: 520px;
      display: grid;
      place-items: center;
    }

    .nd-final-product img {
      position: relative;
      z-index: 2;
      width: min(66%, 430px);
      filter: drop-shadow(0 40px 48px rgba(0, 0, 0, .26));
    }

    .nd-final-product::after {
      content: "";
      position: absolute;
      left: 18%;
      right: 18%;
      bottom: 11%;
      height: 16%;
      border-radius: 50%;
      background: radial-gradient(ellipse, rgba(0, 0, 0, .35), rgba(0, 0, 0, 0) 70%);
      filter: blur(12px);
    }

    .nd-reveal {
      opacity: 0;
      transform: translateY(34px);
      transition: opacity .72s ease, transform .72s cubic-bezier(.2, .8, .2, 1);
    }

    .nd-reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    @media (prefers-reduced-motion: reduce) {
      #nd-formula-home,
      #nd-formula-home * {
        scroll-behavior: auto !important;
        animation-duration: .001ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: .001ms !important;
      }

      .nd-reveal {
        opacity: 1;
        transform: none;
      }
    }

    @media (max-width: 1180px) {
      .nd-hero-grid,
      .nd-formula-layout,
      .nd-product-reveal-grid,
      .nd-use-board,
      .nd-final-grid {
        grid-template-columns: 1fr;
      }

      .nd-hero {
        min-height: auto;
      }

      .nd-hero-copy {
        padding-bottom: 0;
      }

      .nd-hero-visual {
        min-height: 720px;
      }

      .nd-formula-scroll {
        min-height: auto;
      }

      .nd-formula-stage {
        position: relative;
        min-height: auto;
        padding: 88px 0;
      }

      .nd-formula-canvas {
        height: 660px;
      }

      .nd-benefit-system,
      .nd-trust-panel,
      .nd-faq-grid,
      .nd-intro-grid {
        grid-template-columns: 1fr;
      }

      .nd-ingredient-families {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .nd-family:nth-child(2) {
        border-right: 0;
      }

      .nd-family:nth-child(n + 3) {
        border-top: 1px solid rgba(29, 29, 31, .08);
      }
    }

    @media (max-width: 780px) {
      .nd-shell {
        padding: 0 18px;
      }

      .nd-section {
        padding: 74px 0;
      }

      .nd-section-head {
        grid-template-columns: 1fr;
        gap: 18px;
        margin-bottom: 34px;
      }

      .nd-hero {
        padding: 20px 0 46px;
        background:
          radial-gradient(circle at 20% 13%, rgba(218, 248, 85, .25) 0 12%, rgba(218, 248, 85, 0) 36%),
          radial-gradient(circle at 88% 28%, rgba(90, 79, 211, .25) 0 16%, rgba(90, 79, 211, 0) 46%),
          linear-gradient(180deg, #FFFFFF, #F3F0FF 100%);
      }

      .nd-hero-inner {
        min-height: auto;
        gap: 16px;
      }

      .nd-hero-top {
        align-items: flex-start;
      }

      .nd-logo-mark {
        width: 146px;
      }

      .nd-hero-origin {
        font-size: 9px;
        max-width: 156px;
        justify-content: flex-end;
        text-align: right;
        line-height: 1.25;
      }

      .nd-hero-grid {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .nd-hero-visual {
        order: -1;
        width: calc(100% + 28px);
        margin: 18px -14px 0;
        min-height: 470px;
      }

      .nd-studio-plate {
        inset: 4% 2% 3%;
        border-radius: 34px;
      }

      .nd-product-campaign {
