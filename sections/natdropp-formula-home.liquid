          <img src="{{ nd_product_main_url }}" width="420" height="1180" alt="Lavanda Flash">
        </div>
      </div>
    </section>
  </div>

  <script>
    (function () {
      var root = document.querySelector('[data-nd-home]');
      if (!root) return;

      var motionEnabled = root.getAttribute('data-nd-motion') !== 'false';
      var reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var canMotion = motionEnabled && !reduceMotion;

      var revealItems = root.querySelectorAll('.nd-reveal');
      if ('IntersectionObserver' in window) {
        var revealObserver = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              revealObserver.unobserve(entry.target);
            }
          });
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.14 });
        revealItems.forEach(function (item) { revealObserver.observe(item); });
      } else {
        revealItems.forEach(function (item) { item.classList.add('is-visible'); });
      }

      var formula = root.querySelector('[data-nd-formula]');
      var stepItems = formula ? formula.querySelectorAll('[data-nd-steps] article') : [];
      var ticking = false;

      function clamp(value, min, max) {
        return Math.min(Math.max(value, min), max);
      }

      function updateScroll() {
        ticking = false;
        if (!canMotion) {
          root.style.setProperty('--nd-progress', '0');
          return;
        }

        var hero = root.querySelector('.nd-hero');
        if (hero) {
          var heroRect = hero.getBoundingClientRect();
          var heroProgress = clamp((0 - heroRect.top) / Math.max(1, heroRect.height), 0, 1);
          root.style.setProperty('--nd-progress', heroProgress.toFixed(4));
        }

        var docHeight = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
        var pageProgress = clamp(window.scrollY / docHeight, 0, 1);
        root.style.setProperty('--nd-scroll', pageProgress.toFixed(4));
        root.style.setProperty('--nd-section-drift', ((pageProgress - .5) * 34).toFixed(2) + 'px');

        if (formula) {
          var rect = formula.getBoundingClientRect();
          var scrollable = Math.max(1, rect.height - window.innerHeight);
          var progress = clamp((0 - rect.top) / scrollable, 0, 1);
          formula.style.setProperty('--nd-progress', progress.toFixed(4));
          if (stepItems.length) {
            var active = Math.min(stepItems.length - 1, Math.floor(progress * stepItems.length));
            stepItems.forEach(function (item, index) {
              item.classList.toggle('is-active', index === active);
            });
          }
        }
      }

      function requestTick() {
        if (!ticking) {
          ticking = true;
          window.requestAnimationFrame(updateScroll);
        }
      }

      updateScroll();
      window.addEventListener('scroll', requestTick, { passive: true });
      window.addEventListener('resize', requestTick);
    })();
  </script>
</section>
